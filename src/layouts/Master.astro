---
// src/layouts/Master.astro
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';

// On récupère les 3 infos envoyées par la page (avec des valeurs par défaut)
const { 
  title, 
  description = "StressAction : Formations pour la maîtrise du stress et de l'anxiété.", 
  image = "/assets/img/hero-formation-comprendre.png" 
} = Astro.props;
---

<html lang="fr">
<head>
  <BaseHead title={title} description={description} image={image} />
</head>
<body class="index-page">
    
<Navbar /> 
<main class="main">
    <slot />
</main>

<Footer /> 
<a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

<div id="preloader"></div>

<script is:inline src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script is:inline src="/assets/vendor/aos/aos.js"></script>
<script is:inline src="/assets/js/main.js"></script>
</body>
</html>