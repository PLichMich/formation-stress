---
// src/components/ShareButtons.astro
const { title, url } = Astro.props;
---

<div class="share-container mt-5 p-4 rounded-4 bg-white shadow-sm border text-center">
  <h5 class="fw-bold mb-3">Ce programme peut aider un proche ?</h5>
  <p class="small text-muted mb-4">Partagez-lui ces outils en un clic.</p>
  
  <div class="d-flex justify-content-center gap-3">
    <button id="nativeShare" class="btn btn-primary rounded-pill px-4 d-none">
      <i class="bi bi-share me-2"></i> Partager
    </button>

    <div id="fallbackShare" class="d-flex gap-2">
      <a href={`https://www.facebook.com/sharer/sharer.php?u=${url}`} target="_blank" class="btn btn-outline-primary rounded-circle shadow-sm" title="Partager sur Facebook">
        <i class="bi bi-facebook"></i>
      </a>
      <a href={`mailto:?subject=${title}&body=J'ai pensé que cette formation pourrait t'intéresser : ${url}`} class="btn btn-outline-primary rounded-circle shadow-sm" title="Envoyer par Email">
        <i class="bi bi-envelope-fill"></i>
      </a>
      <a href={`https://api.whatsapp.com/send?text=Regarde ce que j'ai trouvé sur StressAction : ${url}`} target="_blank" class="btn btn-outline-success rounded-circle shadow-sm" title="Partager sur WhatsApp">
        <i class="bi bi-whatsapp"></i>
      </a>
    </div>
  </div>
</div>

<script is:inline define:vars={{ title, url }}>
  const shareBtn = document.getElementById('nativeShare');
  const fallback = document.getElementById('fallbackShare');

  // Si le navigateur supporte le partage natif (smartphone)
  if (navigator.share) {
    shareBtn.classList.remove('d-none');
    fallback.classList.add('d-none');

    shareBtn.addEventListener('click', () => {
      navigator.share({
        title: title,
        url: url
      }).catch(console.error);
    });
  }
</script>

<style>
  .share-container {
    border-style: dashed !important;
    border-color: #6f42c1 !important;
  }
  .btn-outline-primary:hover, .btn-outline-success:hover {
    transform: translateY(-3px);
    transition: all 0.2s;
  }
</style>