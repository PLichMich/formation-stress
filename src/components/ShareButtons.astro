---
// src/components/ShareButtons.astro
const { title, url } = Astro.props;
---

<div class="share-container d-flex align-items-center gap-3 my-4">
  <span class="small fw-bold text-muted text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px;">Partager :</span>
  
  <button 
    class="btn btn-outline-primary btn-sm rounded-circle share-btn ez-facebook" 
    data-url={url} 
    title="Partager sur Facebook"
  >
    <i class="bi bi-facebook"></i>
  </button>

  <button 
    class="btn btn-outline-info btn-sm rounded-circle share-btn ez-linkedin" 
    data-url={url} 
    title="Partager sur LinkedIn"
  >
    <i class="bi bi-linkedin"></i>
  </button>

  <button 
    class="btn btn-outline-success btn-sm rounded-circle share-btn" 
    onclick={`window.open('https://api.whatsapp.com/send?text=${encodeURIComponent(title + " " + url)}', '_blank')`}
    title="Partager sur WhatsApp"
  >
    <i class="bi bi-whatsapp"></i>
  </button>

  <a 
    href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`}
    class="btn btn-outline-secondary btn-sm rounded-circle share-btn" 
    title="Envoyer par Email"
  >
    <i class="bi bi-envelope"></i>
  </a>
</div>

<script is:inline src="/assets/vendor/ez-share/ez-share.min.js"></script>

<script is:inline>
  // Utilisation de la méthode exacte demandée par la doc : ezShare.execute()
  document.addEventListener("DOMContentLoaded", function() {
    if (window.ezShare) {
      ezShare.execute();
      console.log("ezShare exécuté avec succès");
    } else {
      console.error("Erreur : ezShare n'est pas chargé. Vérifiez le chemin du fichier JS.");
    }
  });
</script>

<style>
  .share-btn {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    background-color: white;
    border-width: 1px;
    cursor: pointer;
    text-decoration: none; /* Pour la balise <a> de l'email */
  }

  .share-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }

  .btn-outline-primary:hover { background-color: #3b5998; border-color: #3b5998; color: white; }
  .btn-outline-info:hover { background-color: #0077b5; border-color: #0077b5; color: white; }
  .btn-outline-success:hover { background-color: #25d366; border-color: #25d366; color: white; }
  .btn-outline-secondary:hover { background-color: #6c757d; border-color: #6c757d; color: white; }
</style>