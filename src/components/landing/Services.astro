---
// src/components/landing/Services.astro
const sessions = [
  {
    title: "Session 1 : Le Débat Physiologique",
    desc: "Comprendre le rôle de l'adrénaline et du cortisol. Le stress se présente à vous pour expliquer sa raison d'être : vous garder en vie.",
    icon: "bi-activity"
  },
  {
    title: "Session 2 : Le Filtre Cognitif",
    desc: "Analyse de nos pensées sous stress. Apprendre la restructuration cognitive pour ne plus laisser les ruminations dicter votre réalité.",
    icon: "bi-chat-dots"
  },
  {
    title: "Session 3 : Comportements & Stratégies",
    desc: "Repérer les 'ultra-solutions' et sortir du piège du contrôle excessif. Apprendre la différence entre lâcher-prise et indifférence.",
    icon: "bi-arrows-angle-expand"
  },
  {
    title: "Session 4 : Techniques de Régulation",
    desc: "Mise en pratique : Maîtriser la cohérence cardiaque et la relaxation progressive de Jacobson pour apaiser le système nerveux.",
    icon: "bi-wind"
  },
  {
    title: "Session 5 : Présence & Pleine Conscience",
    desc: "Différencier relaxation et pleine conscience. Ancrage des acquis et bilan du parcours pour une autonomie totale.",
    icon: "bi-sun"
  }
];
---
<section id="services" class="services section light-background">

  <div class="container section-title" data-aos="fade-up">
    <h2>Le Parcours Signature</h2>
    <p>Un programme structuré en 5 sessions thématiques basées sur les TCC pour transformer votre relation au stress.</p>
  </div>

  <div class="container">
    <div class="row gy-4">
      {sessions.map((session, index) => (
        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay={100 * (index + 1)}>
          <div class="service-item item-cyan position-relative" style="padding: 40px; background: #fff; border-radius: 15px; box-shadow: 0px 5px 25px rgba(0, 0, 0, 0.05); height: 100%;">
            <div class="icon" style="width: 60px; height: 60px; background: var(--accent-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
              <i class={session.icon} style="color: #fff; font-size: 28px;"></i>
            </div>
            <h3 style="font-weight: 700; font-size: 20px; margin-bottom: 15px;">{session.title}</h3>
            <p style="font-size: 14px; line-height: 1.6; color: #555;">{session.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .service-item {
    transition: all 0.3s ease-in-out;
    border-bottom: 4px solid transparent;
  }
  .service-item:hover {
    transform: translateY(-10px);
    border-color: var(--accent-color);
  }
</style>