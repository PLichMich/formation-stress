---
/* src/components/Hero.astro */
---
<section id="hero" class="hero section dark-background">

  <img src="/assets/img/hero-bg.jpg" alt="Fond gestion du stress" data-aos="fade-in" class="hero-bg">

  <div class="container">
    <div class="row">
      <div class="col-xl-4">
        <h1 data-aos="fade-up">Se libérer du stress</h1>
        <blockquote data-aos="fade-up" data-aos-delay="100">
          <p>
            Découvrez des méthodes concrètes pour transformer votre quotidien et retrouver une sérénité durable. Une formation animée par Michaël Plichart.
          </p>
        </blockquote>
        <div class="d-flex" data-aos="fade-up" data-aos-delay="200">
          <a href="#about" class="btn-get-started">Commencer ici</a>
          <a href="https://www.youtube.com/watch?v=Y7f98aduVJ8" class="glightbox btn-watch-video d-flex align-items-center">
            <i class="bi bi-play-circle"></i><span>Voir la présentation</span>
          </a>
        </div>
      </div>
    </div>
  </div>

</section>

