---
// src/components/Navbar.astro
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const navItems = [
  { name: 'Accueil', href: '/' },
  { name: 'Professionnels', href: '/professionnels' },
  { name: 'Formation', href: '/formations' }, // Mis au singulier car tu as "LA" formation StressLess
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
];
---

<header id="header" class="header d-flex align-items-center fixed-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

    <a href="/" class="logo d-flex align-items-center">
      <img src="/assets/img/logo-stressless.png" alt="Logo StressLess" id="logo-img">
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class={currentPath === item.href ? 'active' : ''}
            >
              {item.name}
            </a>
          </li>
        ))}

        <li class="dropdown">
          <a href="#"><span>Ressources</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
          <ul>
            <li><a href="#">Exercices Respiration</a></li>
            <li><a href="#">Tests de Stress</a></li>
            <li><a href="#">FAQ</a></li>
          </ul>
        </li>
      </ul>
      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

  </div>
</header>

<style>
  /* Style pour le logo */
  #logo-img {
    height: 35px;
    transition: all 0.3s ease;
  }

  /* Sur les pages avec Hero sombre, le logo doit être blanc */
  .index-page #header:not(.scrolled) #logo-img,
  .blog-page #header:not(.scrolled) #logo-img,
  .contact-page #header:not(.scrolled) #logo-img {
    filter: brightness(0) invert(1);
  }

  /* Quand on scrolle ou sur les pages claires, le logo reprend ses couleurs */
  :global(.scrolled) #logo-img {
    filter: none !important;
  }
</style>