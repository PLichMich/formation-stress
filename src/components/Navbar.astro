---
// src/components/Navbar.astro
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, ""); // Enlève le slash final pour comparer proprement

const navItems = [
  { name: 'Accueil', href: '/' },
  { name: 'Professionnels', href: '/professionnels' },
  { name: 'Formations', href: '/formations' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
];
---

<header id="header" class="header d-flex align-items-center fixed-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

<a href="/" class="logo d-flex align-items-center">
<img src="/assets/img/logo-stressless.png" 
     alt="Logo StressLess" 
     style="height: 35px; filter: drop-shadow(0px 0px 2px rgba(255,255,255,0.5));">
</a>

    <nav id="navmenu" class="navmenu">
      <ul>
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class={(currentPath === item.href || (item.href === '/' && currentPath === '')) ? 'active' : ''}
            >
              {item.name}
            </a>
          </li>
        ))}

        {/* Optionnel : Garder un dropdown pour les services spécifiques */}
        <li class="dropdown">
          <a href="#"><span>Ressources</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
          <ul>
            <li><a href="/exercices">Exercices Respiration</a></li>
            <li><a href="/tests">Tests de Stress</a></li>
            <li><a href="/faq">FAQ</a></li>
          </ul>
        </li>
      </ul>
      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

  </div>
</header>

<style>
  /* Par défaut, on force le logo en blanc pour qu'il soit visible sur le Hero sombre */
  .header .logo img {
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease;
  }

  /* Quand on scrolle, Nova ajoute une classe (souvent sur le header ou body) */
  /* Si le header devient blanc au scroll, on retire le filtre pour que le logo redevienne noir */
  :global(.scrolled) .header .logo img {
    filter: none;
  }
</style>