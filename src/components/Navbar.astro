---
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";
---

<header id="header" class="header d-flex align-items-center fixed-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

    <a href="/" class="logo d-flex align-items-center text-decoration-none">
      <span class="logo-text-stress">Stress</span><span class="logo-text-action">Action</span>
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        <li>
          <a href="/" class={currentPath === '/' ? 'active' : ''}>Accueil</a>
        </li>

        <li class="dropdown">
          <a href="/formations" class={currentPath.includes('formations') ? 'active' : ''}>
            <span>Formations</span> <i class="bi bi-chevron-down toggle-dropdown"></i>
          </a>
          <ul>
            <li><a href="/formations">Toutes nos formations</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a href="/formations/comprendre-le-stress">Comprendre le stress</a></li>
          </ul>
        </li>

        <li class="dropdown">
          <a href="/professionnels" class={currentPath.includes('equipe') || currentPath === '/professionnels' ? 'active' : ''}>
            <span>L'Équipe</span> <i class="bi bi-chevron-down toggle-dropdown"></i>
          </a>
          <ul>
            <li><a href="/professionnels">Tous les experts</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a href="/equipe/michael">Michaël Plichart</a></li>
            <li><a href="/equipe/david-vandenbosch">David Vandenbosch</a></li>
            <li><a href="/equipe/celine-mahieu">Céline Mahieu</a></li>
          </ul>
        </li>

        <li>
          <a href="/blog" class={currentPath === '/blog' ? 'active' : ''}>Blog</a>
        </li>
        <li>
          <a href="/contact" class={currentPath === '/contact' ? 'active' : ''}>Contact</a>
        </li>
      </ul>
      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

  </div>
</header>

<style>
  /* STYLES DU LOGO TEXTUEL */
  .logo-text-stress {
    font-size: 24px;
    font-weight: 700;
    color: #444;
    transition: all 0.3s ease;
  }

  .logo-text-action {
    font-size: 24px;
    font-weight: 800;
    color: #6f42c1;
    transition: all 0.3s ease;
  }

  /* GESTION DU LOGO SUR LES PAGES À FOND SOMBRE */
  /* On inclut ici les nouvelles pages de formation pour que le logo soit blanc au début */
  :global(.index-page, .professionnels-page, .equipe-page, .contact-page, .formation-page) #header:not(.scrolled) .logo-text-stress,
  :global(.index-page, .professionnels-page, .equipe-page, .contact-page, .formation-page) #header:not(.scrolled) .logo-text-action {
    color: #ffffff !important;
  }

  /* Quand on scrolle, le logo reprend ses couleurs sur fond blanc */
  :global(.scrolled) .logo-text-stress {
    color: #444 !important;
  }
  :global(.scrolled) .logo-text-action {
    color: #6f42c1 !important;
  }
  
  .dropdown-divider {
    margin: 5px 0;
    opacity: 0.1;
  }
</style>